{
    "name": "java-util/php-collections",
    "description": "PHP 8.1+ port of java.util.Map and related interfaces, mirroring Java API naming and path conventions (PSR-4).",
    "type": "library",
    "license": "GPL-2.0-only",
    "keywords": ["java", "collections", "map", "hashmap", "port", "psr-4"],
    "authors": [
        {
            "name": "Your Name",
            "email": "you@example.com"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.8",
        "phpstan/phpstan-strict-rules": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "Java\\Lang\\": "src/Java/Lang/",
            "Java\\Util\\": "src/Java/Util/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Java\\Util\\": "tests/Java/Util/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "test":      "phpunit",
        "analyse":   "phpstan analyse --memory-limit=256M",
        "cs-check":  "phpcs --standard=PSR12 src/ tests/",
        "cs-fix":    "phpcbf --standard=PSR12 src/ tests/",
        "qa":        ["@test", "@analyse", "@cs-check"]
    },
    "minimum-stability": "stable"
}
